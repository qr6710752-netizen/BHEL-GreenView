
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Authenticated users can read from collections.
    // This is a placeholder, you should refine these rules.
    match /suggestions/{suggestionId} {
      allow read, list: if request.auth != null;
    }

    match /leaderboards/{leaderboardId} {
      allow read, list: if request.auth != null;
    }

    // You might want to lock down other collections further.
    // For example, only admins can write to certain fields.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
